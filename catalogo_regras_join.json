    },
    "tempo": {
      "dataset_preferencial": null,
      "chave_preferencial": "periodo_normalizado"
    },
    "populacao": {
      "dataset_preferencial": "td_populacao_ripsa_ano_2025",
      "chave_preferencial": "co_ibge"
    }
  },
